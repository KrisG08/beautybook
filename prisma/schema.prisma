generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String              @id @default(cuid())
  name                String
  email               String              @unique
  password            String
  phone               String?
  role                String              @default("client")
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  bookings            Booking[]
  business            Business?
  reviews             Review[]
  waitlistEntries     WaitlistEntry[]
  favorites           Favorite[]
  clientNotifications ClientNotification[]
}

model Business {
  id            String         @id @default(cuid())
  userId        String         @unique
  name          String
  contactPerson String
  phone         String
  email         String
  address       String
  description   String?
  category      String
  imageUrl      String?
  status        String         @default("pending")
  commission    Int            @default(10)
  rating        Float          @default(0)
  reviewCount   Int            @default(0)
  bankAccount   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  bookings      Booking[]
  user          User           @relation(fields: [userId], references: [id])
  notifications Notification[]
  reviews       Review[]
  services      Service[]
  timeSlots     TimeSlot[]
  waitlistEntries WaitlistEntry[]
  favorites     Favorite[]
}

model Service {
  id          String    @id @default(cuid())
  businessId  String
  name        String
  duration    Int       @default(30)
  price       Float
  description String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  category    String?
  subtype     String?
  bookings    Booking[]
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  waitlistEntries WaitlistEntry[]
}

model TimeSlot {
  id         String    @id @default(cuid())
  businessId String
  date       String
  startTime  String
  endTime    String
  available  Boolean   @default(true)
  bookings   Booking[]
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Booking {
  id         String   @id @default(cuid())
  userId     String
  businessId String
  serviceId  String
  slotId     String
  status     String   @default("confirmed")
  totalPrice Float
  createdAt  DateTime @default(now())
  slot       TimeSlot @relation(fields: [slotId], references: [id])
  service    Service  @relation(fields: [serviceId], references: [id])
  business   Business @relation(fields: [businessId], references: [id])
  user       User     @relation(fields: [userId], references: [id])
}

model Review {
  id         String   @id @default(cuid())
  userId     String
  businessId String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id])
  user       User     @relation(fields: [userId], references: [id])
}

model Notification {
  id         String   @id @default(cuid())
  businessId String
  type       String
  message    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id])
}

model WaitlistEntry {
  id           String   @id @default(cuid())
  userId       String
  businessId   String
  serviceId    String
  preferredDate String
  preferredTime String
  status       String   @default("waiting")
  notifiedAt   DateTime?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
  business     Business @relation(fields: [businessId], references: [id])
  service      Service  @relation(fields: [serviceId], references: [id])

  @@unique([userId, businessId, serviceId, preferredDate])
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  businessId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  business   Business @relation(fields: [businessId], references: [id])

  @@unique([userId, businessId])
}

model ClientNotification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  businessId String?
  read      Boolean  @default(false)
  actionUrl String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}
