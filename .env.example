# ============================================
# DATABASE CONFIGURATION
# ============================================
# OPTION 1: Local SQLite (ONLY for development on same machine)
# DATABASE_URL="file:./dev.db"

# OPTION 2: Supabase PostgreSQL (REQUIRED for multi-device)
# 1. Go to https://supabase.com and create a free project
# 2. Go to Settings > Database > Connection string > URI
# 3. Copy the URI and replace the placeholder below
# 4. Make sure to add ?pgbouncer=true at the end
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# ============================================
# CAPACITOR (for Android/iOS builds)
# ============================================
# Set this to your deployed server URL when building for mobile
# Example: CAPACITOR_SERVER_URL="https://your-app.vercel.app"
# CAPACITOR_SERVER_URL=""
