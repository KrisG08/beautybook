generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String      @id @default(cuid())
  name          String
  email         String      @unique
  password      String
  phone         String?
  role          String      @default("client")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime   @updatedAt
  
  business      Business?
  bookings     Booking[]
  reviews      Review[]
}

model Business {
  id              String       @id @default(cuid())
  userId          String       @unique
  name            String
  contactPerson   String
  phone           String
  email           String
  address         String
  description    String?
  category       String
  imageUrl       String?
  status         String       @default("pending")
  commission     Int          @default(10)
  rating         Float        @default(0)
  reviewCount    Int          @default(0)
  bankAccount   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  
  user           User         @relation(fields: [userId], references: [id])
  services       Service[]
  bookings       Booking[]
  timeSlots      TimeSlot[]
  reviews       Review[]
}

model Service {
  id          String     @id @default(cuid())
  businessId  String
  name        String
  duration    Int        @default(30)
  price       Float
  description String?
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  
  business    Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  bookings   Booking[]
}

model TimeSlot {
  id          String    @id @default(cuid())
  businessId  String
  date        String
  startTime  String
  endTime    String
  available  Boolean   @default(true)
  
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  bookings  Booking[]
}

model Booking {
  id          String     @id @default(cuid())
  userId      String
  businessId  String
  serviceId   String
  slotId      String
  status     String     @default("confirmed")
  totalPrice Float
  createdAt   DateTime   @default(now())
  
  user        User      @relation(fields: [userId], references: [id])
  business   Business  @relation(fields: [businessId], references: [id])
  service    Service   @relation(fields: [serviceId], references: [id])
  slot       TimeSlot  @relation(fields: [slotId], references: [id])
}

model Review {
  id          String    @id @default(cuid())
  userId      String
  businessId  String
  rating      Int
  comment     String?
  createdAt   DateTime  @default(now())
  
  user        User      @relation(fields: [userId], references: [id])
  business    Business  @relation(fields: [businessId], references: [id])
}